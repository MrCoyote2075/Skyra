{
    "name": "skyra-exam-launcher",
    "version": "4.2.0",
    "description": "Secure Exam Launcher",
    "main": "main.js",
    "author": "Dhanu Corporation",
    "scripts": {
        "prebuild": "node scripts/clean-macos-build.js",
        "start": "electron .",
        "build": "electron-builder",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "build": {
        "appId": "com.dhanucorporation.skyraexamlauncher",
        "productName": "Skyra Exam Launcher",
        "files": [
            "index.html",
            "main.js",
            "preload.js",
            "renderer.js",
            "styles.css",
            "assets/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "assets/AppLogo.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "assets/AppLogo.icns"
        },
        "linux": {
            "target": "AppImage"
        }
    },
    "keywords": [],
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "electron": "^41.0.4",
        "electron-builder": "^26.8.1"
    }
}
